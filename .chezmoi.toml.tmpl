{{- $name := promptStringOnce . "name" "Full name" "Adrián Acosa Sánchez" -}}
{{- $email := promptStringOnce . "email" "Email address" "adrianacosasanchez@proton.me" -}}
{{- $entorno := promptStringOnce . "entorno" "Entorno (personal/adaion)" "personal" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    entorno = {{ $entorno | quote }}

[git]
    autoCommit = true
    autoPush = true

[merge]
    command = "bash"
    args = [
        "-c",
        "cp {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} && code --new-window --wait --merge {{ .Destination | quote }} {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} {{ .Source | quote }}",
    ]

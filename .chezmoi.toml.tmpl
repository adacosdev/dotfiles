{{- $name := promptStringOnce . "name" "Full name" "Adrián Acosa Sánchez" -}}
{{- $entorno := promptChoiceOnce . "entorno" "Environment (personal/work)" (list "personal" "adaion") -}}
{{- $defaultEmail := "adrianacosasanchez@proton.me" -}}
{{- if eq $entorno "adaion" -}}
{{-   $defaultEmail = "adrian.acosa@adaion.energy" -}}
{{- end -}}
{{- $email := promptStringOnce . "email" "Email address" $defaultEmail -}}

[data]
name = {{ $name | quote }}
email = {{ $email | quote }}
entorno = {{ $entorno | quote }}

[git]
# Keep history intentional: review changes before committing/pushing.
autoCommit = false
autoPush = false

[edit]
command = "code"
args = ["--wait"]

[diff]
pager = "delta"

[merge]
command = "code"
args = ["--new-window", "--wait", "--merge"]

#!/usr/bin/env bash
# Post-commit hook for chezmoi - validates templates after each commit
# This hook ensures no invalid templates are committed

set -eo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running template validation..."

# Validate templates
if ! chezmoi dump --format=json > /dev/null 2>&1; then
  echo -e "${RED}✗ Template validation failed!${NC}"
  echo "Fix template errors and try again:"
  chezmoi dump --format=json 2>&1 | head -20
  exit 1
fi

echo -e "${GREEN}✓ Templates are valid${NC}"

# Optionally show what was synced
COMMIT_MSG=$(git log -1 --pretty=%B)
if [[ "$COMMIT_MSG" == *"sync:"* ]]; then
  echo -e "${YELLOW}Config sync commit detected${NC}"
  echo "Changes:"
  git show --stat | grep "^[[:space:]]"
fi

exit 0

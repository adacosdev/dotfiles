# =============================================================================
# ~/.config/zsh/env.zsh — Environment and PATH Configuration
# =============================================================================

# Helper function: prepend to PATH only if not already present
path_prepend() {
  case ":${PATH}:" in
    *:"$1":*) ;;  # Already in PATH
    *) export PATH="$1:$PATH" ;;
  esac
}

# ---------------------------------------------------------------------------
# Local binaries (user-installed tools)
# ---------------------------------------------------------------------------
path_prepend "$HOME/.local/bin"

# ---------------------------------------------------------------------------
# fnm (Fast Node Manager)
# ---------------------------------------------------------------------------
FNM_PATH="{{ .chezmoi.homeDir }}/.local/share/fnm"
if [[ -d "$FNM_PATH" ]]; then
  path_prepend "$FNM_PATH"
  eval "$(fnm env --use-on-cd)"
fi

# ---------------------------------------------------------------------------
# pyenv (Python Version Manager)
# ---------------------------------------------------------------------------
export PYENV_ROOT="$HOME/.pyenv"
if [[ -d "$PYENV_ROOT/bin" ]]; then
  path_prepend "$PYENV_ROOT/bin"
  eval "$(pyenv init -)"
  
  # Only init virtualenv if the plugin is installed
  if [[ -d "$PYENV_ROOT/plugins/pyenv-virtualenv" ]]; then
    eval "$(pyenv virtualenv-init -)"
  fi
fi

# ---------------------------------------------------------------------------
# opencode CLI tools
# ---------------------------------------------------------------------------
if [[ -d "{{ .chezmoi.homeDir }}/.opencode/bin" ]]; then
  path_prepend "{{ .chezmoi.homeDir }}/.opencode/bin"
fi

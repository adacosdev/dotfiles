# =============================================================================
# ~/.config/zsh/env.zsh — Environment and PATH Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# Termux Detection
# ---------------------------------------------------------------------------
IS_TERMUX=0
if [[ -n "$TERMUX_VERSION" ]] || [[ -d "/data/data/com.termux" ]]; then
    IS_TERMUX=1
fi

# ---------------------------------------------------------------------------
# nvm (Node Version Manager)
# ---------------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"
if [[ -d "$NVM_DIR" ]]; then
  # Load nvm if it exists (lazy-loads Node)
  export NVM_LOADED=0
  nvm() {
    [[ $NVM_LOADED -eq 1 ]] && builtin nvm "$@" && return
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    NVM_LOADED=1
    nvm "$@"
  }
fi

# ---------------------------------------------------------------------------
# Volta (alternative Node manager — check if Volta is installed)
# ---------------------------------------------------------------------------
if [[ -f "$HOME/.volta/bin/volta" ]]; then
  export VOLTA_HOME="$HOME/.volta"
  path_prepend "$VOLTA_HOME/bin"
fi

# ---------------------------------------------------------------------------
# Homebrew setup (skip on Termux)
# ---------------------------------------------------------------------------
if [[ $IS_TERMUX -eq 0 ]]; then
    if [[ "$(uname)" == "Darwin" ]]; then
        # macOS - check for Apple Silicon vs Intel
        if [[ -f "/opt/homebrew/bin/brew" ]]; then
            # Apple Silicon (M1/M2/M3)
            BREW_BIN="/opt/homebrew/bin"
        elif [[ -f "/usr/local/bin/brew" ]]; then
            # Intel Mac
            BREW_BIN="/usr/local/bin"
        fi
    else
        # Linux
        BREW_BIN="/home/linuxbrew/.linuxbrew/bin"
    fi

    # Only eval brew shellenv if brew is installed
    if [[ -n "$BREW_BIN" && -f "$BREW_BIN/brew" ]]; then
        eval "$($BREW_BIN/brew shellenv)"
    fi
fi

# ---------------------------------------------------------------------------
# Editors
# ---------------------------------------------------------------------------
export EDITOR="nvim"
export VISUAL="nvim"

# ---------------------------------------------------------------------------
# Projects
# ---------------------------------------------------------------------------
export PROJECT_PATHS="{{ .chezmoi.homeDir }}/work"

# ---------------------------------------------------------------------------
# TMUX / Zellij window manager detection
# ---------------------------------------------------------------------------
export WM_VAR="/$TMUX"
export WM_CMD="tmux"

# ---------------------------------------------------------------------------
# LS_COLORS
# ---------------------------------------------------------------------------
export LS_COLORS="di=38;5;67:ow=48;5;60:ex=38;5;132:ln=38;5;144:*.tar=38;5;180:*.zip=38;5;180:*.jpg=38;5;175:*.png=38;5;175:*.mp3=38;5;175:*.wav=38;5;175:*.txt=38;5;223:*.sh=38;5;132"

# ---------------------------------------------------------------------------
# start_if_needed — launch tmux in interactive terminal
# ---------------------------------------------------------------------------
start_if_needed() {
    if [[ $- == *i* ]] && [[ -z "${WM_VAR#/}" ]] && [[ -t 1 ]]; then
        exec $WM_CMD
    fi
}

# ---------------------------------------------------------------------------
# LS wrapper (platform-specific)
# ---------------------------------------------------------------------------
if [[ "$(uname)" == "Darwin" ]]; then
  alias ls='ls --color=auto'
else
  alias ls='gls --color=auto'
fi

# ---------------------------------------------------------------------------
# Interactive session guard
# ---------------------------------------------------------------------------
if [[ $- != *i* ]]; then
    return
fi

# Helper function: prepend to PATH only if not already present
path_prepend() {
  case ":${PATH}:" in
    *:"$1":*) ;;  # Already in PATH
    *) export PATH="$1:$PATH" ;;
  esac
}

# ---------------------------------------------------------------------------
# Local binaries (user-installed tools)
# ---------------------------------------------------------------------------
path_prepend "$HOME/.local/bin"

# ---------------------------------------------------------------------------
# fnm (Fast Node Manager)
# ---------------------------------------------------------------------------
FNM_PATH="{{ .chezmoi.homeDir }}/.local/share/fnm"
if [[ -d "$FNM_PATH" ]]; then
  path_prepend "$FNM_PATH"
  eval "$(fnm env --use-on-cd)"
fi

# ---------------------------------------------------------------------------
# pyenv (Python Version Manager)
# ---------------------------------------------------------------------------
export PYENV_ROOT="$HOME/.pyenv"
if [[ -d "$PYENV_ROOT/bin" ]]; then
  path_prepend "$PYENV_ROOT/bin"
  eval "$(pyenv init -)"
  
  # Only init virtualenv if the plugin is installed
  if [[ -d "$PYENV_ROOT/plugins/pyenv-virtualenv" ]]; then
    eval "$(pyenv virtualenv-init -)"
  fi
fi

# ---------------------------------------------------------------------------
# opencode CLI tools
# ---------------------------------------------------------------------------
if [[ -d "{{ .chezmoi.homeDir }}/.opencode/bin" ]]; then
  path_prepend "{{ .chezmoi.homeDir }}/.opencode/bin"
fi

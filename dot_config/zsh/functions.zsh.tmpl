# =============================================================================
# ~/.config/zsh/functions.zsh — Utility Functions
# =============================================================================

# Open files in VS Code with fuzzy find
cf() { # > Find file and open in VS Code
  local file
  file=$(fd --type f --strip-cwd-prefix --hidden --exclude .git | \
    fzf --preview 'bat --color=always --style=numbers --line-range :500 {}' \
        --header "Select file to open in VS Code")
  
  [[ -n "$file" ]] && code "$file"
}

# Fuzzy find and jump into a directory
zf() { # > Find folder and jump into it
  local dir
  dir=$(fd --type d --strip-cwd-prefix --hidden --exclude .git | \
    fzf --header "Select directory")
  
  [[ -n "$dir" ]] && z "$dir"
}

# Search projects directory and open in VS Code
p() { # > Search project and open in VS Code
  local dir
  dir=$(fd --type d --max-depth 2 . ~/Dev 2>/dev/null | \
    fzf --header "Select project")
  
  # Only change directory and open if a selection was made
  [[ -n "$dir" ]] && cd "$dir" && code .
}

# Show aliases and functions with descriptions
h() { # > Show aliases and functions help
  if ! command -v fzf &>/dev/null; then
    echo "⚠️ fzf is required for this command."
    return 1
  fi

  (
    # Extract aliases with descriptions
    grep -Eh '^alias ' $HOME/.config/zsh/*.zsh 2>/dev/null | perl -ne '
      if (/alias\s+([^=]+)=\x27?([^\x27#]+)\x27?\s*#\s*>\s*(.*)/) {
        printf "\033[32m%-12s\033[0m \033[34m→\033[0m \033[37m%-55s\033[0m \033[90m# %s\033[0m\n", $1, $2, $3;
      }'

    # Extract functions with descriptions
    grep -Eh '^[a-zA-Z0-9_-]+\s*\(\)\s*\{' $HOME/.config/zsh/*.zsh 2>/dev/null | perl -ne '
      if (/^([a-zA-Z0-9_-]+)\s*\(\)\s*\{\s*#\s*>\s*(.*)/) {
        printf "\033[36m%-12s\033[0m \033[34m(f)\033[0m \033[37m%-55s\033[0m \033[90m# %s\033[0m\n", $1, "function", $2;
      }'
  ) | sort | fzf \
    --ansi \
    --height 60% \
    --reverse \
    --border \
    --header " 💊 DOTFILES CHEATSHEET " \
    --color="header:italic:cyan,border:blue,fg+:yellow,pointer:magenta" \
    --prompt "Search > " \
    --preview 'echo {} | perl -pe "s/.*# //"' \
    --preview-window=up:wrap
}

# Interactive history search with fzf
hs() { # > Interactive history search with fzf
  if ! command -v fzf &>/dev/null; then
    history 0
    return
  fi
  
  local cmd
  # fc -l (list) -n (no numbers) -r (reverse order)
  cmd=$(fc -lnr 1 | \
    fzf --no-sort --exact --query "$1" \
        --header "Press ENTER to add to command line for editing")
  
  if [[ -n "$cmd" ]]; then
    # Use print -z to add to command line for review, not execute
    print -z "$cmd"
  fi
}

# =============================================================================
# Chezmoi Auto-Commit Functions
# =============================================================================

# Auto-add and commit changes to chezmoi dotfiles
cm() { # > Chezmoi auto-add + commit (with optional message)
  local msg="${1:-update $(date '+%Y-%m-%d %H:%M')}"
  local chezmoi_dir="$HOME/.local/share/chezmoi"
  
  # Check if there are changes
  if [[ -z "$(git -C "$chezmoi_dir" status --porcelain 2>/dev/null)" ]]; then
    echo "📝 No changes to commit"
    return 0
  fi
  
  # Add all changes and commit
  git -C "$chezmoi_dir" add -A
  git -C "$chezmoi_dir" commit -m "$msg"
  
  # Optionally push (uncomment if you want auto-push)
  # git -C "$chezmoi_dir" push
  
  echo "✅ Changes committed: $msg"
}

# Quick commit with fzf to select which files to commit
cmm() { # > Chezmoi commit with fzf file selection
  local chezmoi_dir="$HOME/.local/share/chezmoi"
  local selected
  
  selected=$(git -C "$chezmoi_dir" status --porcelain | \
    fzf --multi --header "Select files to commit" | \
    awk '{print $2}')
  
  if [[ -z "$selected" ]]; then
    echo "No files selected"
    return 1
  fi
  
  echo "Selected files:"
  echo "$selected"
  echo ""
  echo -n "Commit message: "
  read -r msg
  
  if [[ -z "$msg" ]]; then
    echo "❌ No commit message"
    return 1
  fi
  
  echo "$selected" | xargs git -C "$chezmoi_dir" add
  git -C "$chezmoi_dir" commit -m "$msg"
  echo "✅ Committed: $msg"
}

# =============================================================================
# Terminal Multiplexer Auto-Start
# =============================================================================

# Auto-start tmux or zellij when opening a terminal (from Gentleman.Dots)
# Set WM_CMD to 'tmux' or 'zellij' to choose which one to use
export WM_CMD="${WM_CMD:-tmux}"

start_if_needed() { # > Auto-start tmux/zellij if not already inside a session
  # Skip if already inside tmux or zellij
  [[ -n "$TMUX" || -n "$ZELLIJ" ]] && return

  # Skip if not in an interactive terminal
  [[ ! -t 1 ]] && return

  # Skip inside IDEs / editors
  [[ -n "$VSCODE_PID" || -n "$VSCODE_INJECTION" || "$TERM_PROGRAM" == "vscode" ]] && return
  [[ -n "$INTELLIJ_ENVIRONMENT_READER" ]] && return

  case "$WM_CMD" in
    tmux)
      if command -v tmux &>/dev/null; then
        # Attach to existing session or create a new one
        tmux attach-session 2>/dev/null || tmux new-session
      fi
      ;;
    zellij)
      if command -v zellij &>/dev/null; then
        zellij attach --create
      fi
      ;;
  esac
}

start_if_needed

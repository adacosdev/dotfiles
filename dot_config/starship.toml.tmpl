add_newline = false
command_timeout = 3600000
palette = "gentleman"

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_status\
$git_metrics\
$fill\
$nodejs\
$rust\
$golang\
$python\
$java\
$c\
$zig\
$bun\
$php\
$docker_context\
$kubernetes\
$aws\
$cmd_duration\
$time\
$line_break\
$character"""

# =============================================================================
# Palettes
# =============================================================================

[palettes.gentleman]
text      = "#F3F6F9"
red       = "#CB7C94"
green     = "#B7CC85"
yellow    = "#FFE066"
blue      = "#7FB4CA"
mauve     = "#A3B5D6"
pink      = "#FF8DD7"
teal      = "#7AA89F"
peach     = "#DEBA87"
subtext0  = "#5C6170"
overlay0  = "#232A40"
rosewater = "#E0C15A"
flamingo  = "#FF8DD7"
maroon    = "#C4746E"
lavender  = "#B99BF2"
subtext1  = "#8A8FA3"
overlay2  = "#313342"
overlay1  = "#191E28"
surface2  = "#27345C"
surface1  = "#232A40"
surface0  = "#191E28"
base      = "none"
mantle    = "#06080f"
crust     = "#06080f"

[palettes.catppuccin_mocha]
rosewater = "#f5e0dc"
flamingo  = "#f2cdcd"
pink      = "#f5c2e7"
mauve     = "#cba6f7"
red       = "#f38ba8"
maroon    = "#eba0ac"
peach     = "#fab387"
yellow    = "#f9e2af"
green     = "#a6e3a1"
teal      = "#94e2d5"
sky       = "#89dceb"
sapphire  = "#74c7ec"
blue      = "#89b4fa"
lavender  = "#b4befe"
text      = "#cdd6f4"
subtext1  = "#bac2de"
subtext0  = "#a6adc8"
overlay2  = "#9399b2"
overlay1  = "#7f849c"
overlay0  = "#6c7086"
surface2  = "#585b70"
surface1  = "#45475a"
surface0  = "#313244"
base      = "#1e1e2e"
mantle    = "#181825"
crust     = "#11111b"

# =============================================================================
# Prompt character
# =============================================================================

[fill]
symbol = " "

[character]
{{ if eq .entorno "adaion" -}}
success_symbol = "[💼 ➜](bold fg:blue) "
{{ else -}}
success_symbol = "[🏠 ➜](bold fg:green) "
{{ end -}}
error_symbol   = "[➜](bold fg:red) "

# =============================================================================
# Context
# =============================================================================

[username]
show_always  = false
style_user   = "bold fg:yellow"
style_root   = "bold fg:red"
format       = "[$user]($style_user) "

[hostname]
ssh_only = true
style    = "bold fg:teal"
format   = "on [$hostname]($style) "

[directory]
style                 = "bold fg:blue"
format                = "[$path]($style)[$read_only]($read_only_style) "
truncation_length     = 2
truncation_symbol     = "…/"
truncate_to_repo      = true
read_only             = "  "
read_only_style       = "fg:blue"
before_repo_root_style = "fg:blue"

[directory.substitutions]
"Documents" = "󰈙 "
"Downloads" = " "
"Music"     = " "
"Pictures"  = " "

# =============================================================================
# Git
# =============================================================================

[git_branch]
symbol = " "
style  = "bold fg:mauve"
format = "on [$symbol$branch]($style) "

[git_status]
style  = "fg:red"
format = "([\\[$all_status$ahead_behind\\]]($style) )"
conflicted = "="
ahead      = "⇡"
behind     = "⇣"
untracked  = "?"
modified   = "!"
staged     = "+"
deleted    = "✘"

[git_metrics]
disabled = false
format   = "([+$added]($added_style) )([-$deleted]($deleted_style) )"

# =============================================================================
# Languages
# =============================================================================

[nodejs]
symbol       = " "
style        = "bold fg:green"
format       = '[[ $symbol ($version) ](fg:green)]($style)'
detect_files = ["package.json", "node_modules"]

[python]
symbol           = " "
style            = "bold fg:peach"
format           = "[$symbol$pyenv_prefix($version)( $virtualenv)](fg:peach) "
pyenv_version_name = true
detect_files     = [".python-version", "pyproject.toml", "requirements.txt", ".venv", "setup.py"]
disabled         = false

[rust]
symbol = " "
style  = "bold fg:red"
format = '[[ $symbol ($version) ](fg:red)]($style)'

[golang]
symbol = " "
style  = "bold fg:teal"
format = '[[ $symbol ($version) ](fg:teal)]($style)'

[java]
symbol         = " "
style          = "bold fg:red"
format         = '[[ $symbol ($version) ](fg:red)]($style)'
version_format = "$raw"
disabled       = false

[c]
symbol         = " "
style          = "bold fg:blue"
format         = '[[ $symbol ($version) ](fg:blue)]($style)'
version_format = "$raw"
disabled       = false

[zig]
style          = "bold fg:peach"
format         = '[[ $symbol ($version) ](fg:peach)]($style)'
version_format = "$raw"
disabled       = false

[bun]
style          = "bold fg:text"
format         = '[[ $symbol ($version) ](fg:text)]($style)'
version_format = "$raw"
disabled       = false

[php]
symbol         = " "
style          = "bold fg:peach"
format         = '[[ $symbol ($version) ](fg:peach)]($style)'
version_format = "$raw"
disabled       = false

# =============================================================================
# Cloud / Infrastructure
# =============================================================================

[docker_context]
symbol   = " "
style    = "bold fg:blue"
format   = "via [$symbol$context]($style) "
disabled = false

[kubernetes]
disabled = false
symbol   = "☸ "
style    = "bold fg:teal"
format   = "via [$symbol($context)]($style) "

[aws]
disabled = false
symbol   = "☁️ "
style    = "bold fg:peach"
format   = "via [$symbol($profile)]($style) "

# =============================================================================
# Misc
# =============================================================================

[time]
disabled    = false
style       = "bold fg:subtext0"
format      = '[[   $time ](fg:subtext0)]($style)'
time_format = "%R"

[cmd_duration]
min_time = 500
style    = "italic fg:yellow"
format   = " took [ $duration]($style) "

{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -eo pipefail

source "{{ joinPath .chezmoi.sourceDir "bootstrap/linux/helpers/progress.sh" }}"

# =============================================================================
# Main Script: Install Runtimes (Node/Python)
# =============================================================================
show_progress "🛠️ Installing runtimes" 50

# --- FNM (Fast Node Manager) ---
if ! command -v fnm &> /dev/null; then
    show_progress "🛠️ Installing runtimes: fnm" 52
    curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
    export PATH="$HOME/.local/share/fnm:$PATH"
    eval "$(fnm env)"
    
    show_progress "🛠️ Installing runtimes: Node.js LTS" 56
    fnm install --lts
    fnm use --lts
else
    show_progress "🛠️ Installing runtimes: fnm (already installed)" 56
fi

# --- PYENV (Python Version Manager) ---
if [ ! -d "$HOME/.pyenv" ]; then
    show_progress "🛠️ Installing runtimes: pyenv dependencies" 58
    # Dependencias necesarias para compilar Python en varias distros
    {{ if eq .chezmoi.osRelease.id "ubuntu" "debian" -}}
    sudo apt update && sudo apt install -y build-essential libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev curl git libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev
    {{ else if eq .chezmoi.osRelease.id "arch" "endeavouros" -}}
    sudo pacman -S --noconfirm base-devel openssl zlib bzip2 readline sqlite curl git ncurses xz tk libxml2 libffi
    {{ end -}}
    
    show_progress "🛠️ Installing runtimes: pyenv" 62
    curl https://pyenv.run | bash
else
    show_progress "🛠️ Installing runtimes: pyenv (already installed)" 62
fi

show_progress_done "Runtime environments installed successfully"
{{ end -}}

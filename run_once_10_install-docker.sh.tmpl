{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -eo pipefail

source "{{ joinPath .chezmoi.sourceDir "bootstrap/linux/helpers/progress.sh" }}"

# =============================================================================
# Main Script: Configure Docker
# =============================================================================
show_progress "🐳 Configuring Docker" 35

install_docker() {
    {{ if eq .chezmoi.osRelease.id "ubuntu" "debian" -}}
    sudo apt update
    sudo apt install -y docker.io docker-compose
    sudo systemctl enable --now docker
    sudo usermod -aG docker $USER
    {{ else if eq .chezmoi.osRelease.id "arch" "endeavouros" -}}
    sudo pacman -S --noconfirm docker docker-compose
    sudo systemctl enable --now docker
    sudo usermod -aG docker $USER
    {{ else if eq .chezmoi.osRelease.id "fedora" -}}
    sudo dnf install -y moby-engine docker-compose
    sudo systemctl enable --now docker
    sudo usermod -aG docker $USER
    {{ end -}}
}

if ! command -v docker &> /dev/null; then
    show_progress "🐳 Configuring Docker: installing" 40
    install_docker
    show_progress_done "Docker installed. NOTE: Restart your session to apply group permissions."
else
    show_progress_done "Docker already installed."
fi
{{ end -}}

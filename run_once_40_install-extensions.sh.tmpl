{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -eo pipefail

source "{{ joinPath .chezmoi.sourceDir "bootstrap/linux/helpers/progress.sh" }}"

# =============================================================================
# Main Script: Sync Editor Extensions
# =============================================================================
show_progress "🔌 Syncing editor extensions" 80

extensions=(
{{ range .extensions.common.editors -}}
{{ . }}
{{ end -}}
)

install_extensions() {
  local cmd=$1
  local name=$2
  local total=${#extensions[@]}
  
  if ! command -v "$cmd" &> /dev/null; then
    return
  fi

  local installed_exts
  installed_exts=$("$cmd" --list-extensions 2>/dev/null || echo "")
  local count=0

  for ext in "${extensions[@]}"; do
    count=$((count + 1))
    pct=$((80 + count * 20 / total))
    
    if ! echo "$installed_exts" | grep -iq "^$ext$"; then
      show_progress "🔌 Installing in $name: $ext" "$pct"
      "$cmd" --install-extension "$ext" --force 2>/dev/null || true
    fi
  done
}

install_extensions "code" "VS Code"
install_extensions "cursor" "Cursor"
install_extensions "antigravity" "Antigravity"

show_progress_done "Editor extensions synced successfully"
{{ end -}}
